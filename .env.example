# ─── Market Data APIs (free tier, no credit card) ─────────────────────────────

# Alpha Vantage — 25 req/day free
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Finnhub — 60 req/min free
# Get key: https://finnhub.io/register
FINNHUB_KEY=your_finnhub_key_here

# ─── AI Intelligence APIs (free tier, no credit card) ─────────────────────────

# Groq — LLaMA 3.3 / DeepSeek — 30 RPM free
# Get key: https://console.groq.com  (sign in with Google)
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA NIM — Mistral / Nemotron — free prototyping tier
# Get key: https://build.nvidia.com  (join NVIDIA Developer Program, free)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Tavily Search — 1000 requests/month free
# Get key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Transport ─────────────────────────────────────────────────────────────────

# stdio  → for Claude Desktop, Cursor, Codex, Windsurf, Continue, Zed (default)
# http   → for Manus, remote agents, web deployments
MCP_TRANSPORT=stdio

# Port used when MCP_TRANSPORT=http
PORT=7860

# ─── Optional: AI model overrides ──────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_MODEL=mistralai/mistral-7b-instruct-v0.3
